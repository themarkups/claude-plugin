# CATAAM MCP connector — environment configuration.
# Copy to `.env` and fill in. NEVER commit real secrets.

# Base URL of the CATAAM API (no trailing slash). Default: https://service.cataam.com
# (cataam.com is the marketing site; the API is served from service.cataam.com)
CATAAM_BASE_URL=https://service.cataam.com

# --- Auth: choose ONE mode ---

# Mode 1 (recommended, target integration path): API key.
# Generated in the CATAAM UI (Integrations → API Keys). Looks like: cataam_<hex>
# CATAAM_API_KEY=cataam_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mode 2 (works today): username/password → short-lived JWT (auto-refreshed).
# CATAAM_USERNAME=you@example.com
# CATAAM_PASSWORD=your-password

# Transport: stdio (default, for the Claude plugin) or http (remote streamable-HTTP).
# MCP_TRANSPORT=stdio
# PORT=3000
