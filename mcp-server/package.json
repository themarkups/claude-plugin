{
  "name": "cataam-mcp-server",
  "version": "0.1.6",
  "description": "MCP connector for Cataam \u2014 the GRC/compliance-automation platform (SOC2, GDPR, ISO27001). Exposes the /api/audit compliance surface and the OKF Context Engine as MCP tools.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cataam-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "INSTALL.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/themarkups/claude-plugin.git",
    "directory": "mcp-server"
  },
  "homepage": "https://github.com/themarkups/claude-plugin#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "smoke": "node test/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "express": "^4.21.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
